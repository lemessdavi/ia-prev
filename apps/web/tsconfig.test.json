{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist-test",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "types": ["node"],
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "incremental": false,
    "tsBuildInfoFile": "dist-test/.tsbuildinfo"
  },
  "include": ["src/lib/business-error.ts", "test/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
