{
  "name": "universal-react-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -k -n convex,apps \"pnpm convex:dev\" \"turbo dev --filter=web --filter=mobile\"",
    "dev:apps": "turbo dev --filter=web --filter=mobile",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "build": "pnpm convex:codegen:if-configured && turbo build",
    "lint": "turbo lint",
    "typecheck": "pnpm convex:codegen:if-configured && turbo typecheck",
    "compile": "pnpm run typecheck",
    "test": "pnpm --filter @repo/convex-backend test && pnpm --filter web test",
    "convex:dev": "pnpm --filter @repo/convex-backend dev",
    "convex:codegen:if-configured": "bash ./scripts/convex-codegen-if-configured.sh",
    "convex:codegen": "pnpm --filter @repo/convex-backend codegen",
    "convex:seed": "pnpm --filter @repo/convex-backend seed"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.7.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "react-native-web": "0.21.1",
      "tailwindcss": "3.4.18"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
