{
  "name": "universal-react-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n convex,apps \"pnpm convex:dev\" \"turbo dev --filter=web --filter=mobile\"",
    "dev:apps": "turbo dev --filter=web --filter=mobile",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "build": "pnpm convex:codegen:if-configured && turbo build",
    "lint": "turbo lint",
    "typecheck": "pnpm convex:codegen:if-configured && turbo typecheck",
    "compile": "pnpm run typecheck",
    "test": "pnpm --filter @repo/convex-backend test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=chromium-desktop --workers=1",
    "test:e2e:debug": "PWDEBUG=1 playwright test --project=chromium-desktop --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "convex:dev": "bash ./scripts/convex-dev-if-configured.sh",
    "convex:dev:force": "pnpm --filter @repo/convex-backend dev",
    "convex:codegen:if-configured": "bash ./scripts/convex-codegen-if-configured.sh",
    "convex:codegen": "pnpm --filter @repo/convex-backend codegen",
    "convex:seed": "pnpm --filter @repo/convex-backend seed",
    "backend:compile": "npm --prefix packages/backend run compile",
    "backend:test": "npm --prefix packages/backend run compile && npm --prefix packages/backend run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "concurrently": "^9.2.1",
    "turbo": "^2.7.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "react-native-web": "0.21.1",
      "tailwindcss": "3.4.18"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
