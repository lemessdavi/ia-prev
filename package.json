{
  "name": "universal-react-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "compile": "turbo typecheck",
    "test": "pnpm -r --if-present test",
    "backend:compile": "npm --prefix packages/backend run compile",
    "backend:test": "npm --prefix packages/backend run compile && npm --prefix packages/backend run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "turbo": "^2.7.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "react-native-web": "0.21.1",
      "tailwindcss": "3.4.18"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
