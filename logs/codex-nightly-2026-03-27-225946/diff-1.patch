a em portugues do Brasil, em no maximo 3 frases, pedindo proximo dado objetivo quando faltar contexto.'\\\\n          },\\\\n          {\\\\n            role: 'user',\\\\n            content: inboundText\\\\n          }\\\\n        ]\\\\n      })\\\\n    });\\\\n\\\\n    if (response.ok) {\\\\n      const data = await response.json();\\\\n      const liveReply = data?.choices?.[0]?.message?.content;\\\\n      if (typeof liveReply === 'string' && liveReply.trim().length > 0) {\\\\n        aiMode = 'live';\\\\n        replyText = liveReply.trim();\\\\n      }\\\\n    }\\\\n  } catch (error) {\\\\n    // fallback para mock quando live falhar\\\\n  }\\\\n}\\\\n\\\\nif (\"'!replyText) {'\"\\\\n  const compact = inboundText.replace(/\\\\\\\\s+/g, ' ').trim().slice(0, 80);\\\\n  replyText = \"'`Recebi: '\"\\\\\\\"\"'${compact}'\"\\\\\\\". Para continuar a triagem, informe seu nome completo e a data de inicio do problema previdenciario.\"'`;'\"\\\\n}\\\\n\\\\nreturn [{\\\\n  json: {\\\\n    choices: [\\\\n      {\\\\n        message: {\\\\n          content: replyText\\\\n        }\\\\n      }\\\\n    ],\\\\n    aiMode,\\\\n    model: aiMode === 'live' ? (\"'$env.OPENAI_MODEL || '\"'gpt-4.1-mini') : 'mock-deterministic-v1'\\\\n  }\\\\n}];\\\"\n      },\n      id: '6f326e81-caf6-4df6-87c9-5e6dff6c1642',\n      name: 'AI Reply (Mock or Live)',\n      type: 'n8n-nodes-base.code',\n      typeVersion: 2,\n      position: [\n        1060,\n        320\n      ]\n    };\n  }\n\n  if (node.name === 'Persist Outbound (Convex)') {\n    return {\n      ...node,\n      parameters: {\n        ...node.parameters,\n        jsonBody:\n          \\\"={{ { phoneNumberId: \"'$('\"'Normalize Inbound').item.json.phoneNumberId, conversationId: \"'$('\"'Persist Inbound (Convex)').item.json.conversationId, externalMessageId: \"'$json.messages?.[0]?.id, body: $('\"'AI Reply (Mock or Live)').item.json.choices?.[0]?.message?.content || 'Resposta enviada pelo assistente.' } }}\\\",\n      },\n    };\n 